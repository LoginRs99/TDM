# docker-compose.override.yml.example
# 
# Copy this file to docker-compose.override.yml to customize your local setup
# This file is automatically merged with docker-compose.yml
#
# Example: cp docker-compose.override.yml.example docker-compose.override.yml

services:
  twitch-drops-miner:
    # ========================================
    # DEVELOPMENT OVERRIDES
    # ========================================
    
    # Build configuration (optional)
    # build:
    #   context: .
    #   target: final
    #   args:
    #     - PYTHON_VERSION=3.11
    
    # Development volumes - mount source code for hot reload
    volumes:
      # Override the default volumes if needed
      - ./files/settings.json:/home/appuser/app/settings.json:ro
      - ./files/cookies.jar:/home/appuser/app/cookies.jar
      - ./files/logs:/home/appuser/app/logs
      
      # Uncomment to mount source code for development
      # WARNING: This makes the container use your local code
      # - ./:/home/appuser/app:ro
      
      # Development-specific config files
      # - ./dev-config/settings.json:/home/appuser/app/settings.json:ro
    
    # Environment variable overrides
    environment:
      # Logging
      - LOGGING_LEVEL=DEBUG  # DEBUG, INFO, WARNING, ERROR
      - PYTHONUNBUFFERED=1
      
      # Discord notifications (set your webhook here)
      # - DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
      # - DISCORD_SUMMARY_INTERVAL=60  # minutes
      
      # Performance tuning
      # - MAINTENANCE_INTERVAL_MINUTES=15
      # - PRIORITY_MODE=BALANCED  # PRIORITY_ONLY, ENDING_SOONEST, LOW_AVBL_FIRST, BALANCED
      
      # Timezone
      - TZ=UTC
    
    # Resource limits (adjusted for development)
    # deploy:
    #   resources:
    #     limits:
    #       cpus: '0.75'
    #       memory: 512M
    #     reservations:
    #       memory: 128M
    
    # ========================================
    # PRODUCTION OVERRIDES
    # ========================================
    # Uncomment these for production use
    
    # Restart policy
    # restart: always
    
    # Healthcheck (optional tuning)
    # healthcheck:
    #   test: ["CMD", "python", "healthcheck.py"]
    #   interval: 30s      # More frequent checks
    #   timeout: 10s
    #   retries: 5         # More retries before marking unhealthy
    #   start_period: 60s  # Longer startup grace period
    
    # Logging configuration
    # logging:
    #   driver: "json-file"
    #   options:
    #     max-size: "50m"  # Larger logs
    #     max-file: "5"    # More log files
    
    # Network configuration (if using custom networks)
    # networks:
    #   - twitch_network
    
# Custom networks (if needed)
# networks:
#   twitch_network:
#     driver: bridge
