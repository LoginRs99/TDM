# .dockerignore

# Git and editor-specific files
.git
.gitignore
.github/
.vscode/
.env
*.env

# Docker-specific files that shouldn't be in the image context
Dockerfile
docker-compose.yml
docker-compose.*.yml
.dockerignore

# Host-mounted runtime data. The image should contain app code only.
files/
logs/
metrics.json
healthcheck.timestamp
watch_stats.json

# Python virtual environment and cache
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Build artifacts and packaging files (for PyInstaller, etc.)
build/
dist/
*.spec
appimage/
build.bat
build.sh
pack.bat

# Local development and testing files
TEST/
test.py
test.txt
run_dev.bat
setup_env.bat
setup_env.sh

# Runtime-generated files that should not be baked into the image.
# These should be generated by the container at runtime or mounted as volumes.
*.log
log.txt
lock.file
healthcheck.timestamp
cookies.jar
settings.json

# Documentation (optional, but good practice to exclude for a lean image)
README.md
manual.txt
LICENSE
